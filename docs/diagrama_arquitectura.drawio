            <Array as="points">
              <mxPoint x="1460" y="340" />
              <mxPoint x="1460" y="255" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 4. Groq API → decision (respuesta del LLM, dashed) -->
        <mxCell id="a4" value="tool_call o content"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=12;dashed=1;dashPattern=8 4;exitX=0;exitY=0.5;exitDx=0;exitDy=0;"
          edge="1" source="groq_model" target="decision" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1460" y="255" />
              <mxPoint x="1460" y="680" />
              <mxPoint x="870" y="680" />
              <mxPoint x="870" y="547" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 5. decision → exec_tool (Sí) -->
        <mxCell id="a5" value="Sí — hay tool_call"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=12;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="decision" target="exec_tool" parent="1">
          <mxGeometry relative="1" as="geometry" />
