        <!-- ════════════════════════════════════════ -->

        <!-- 1. Usuario → chat() -->
        <mxCell id="a1" value="prompt"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=12;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
