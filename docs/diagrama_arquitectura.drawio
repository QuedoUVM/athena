              <mxPoint x="540" y="340" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 3. Groq Client → Groq API -->
        <mxCell id="a3" value="POST + messages + tools"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=12;exitX=1;exitY=0.5;exitDx=0;exitDy=0;"
          edge="1" source="groq_client" target="groq_model" parent="1">
